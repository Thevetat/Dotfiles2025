#!/usr/bin/env zsh
emulate -L zsh

for arg in "$@"; do
  case "$arg" in
    -o|-out|-version|-help|--help)
      if [[ -x /usr/bin/xclip ]]; then
        exec /usr/bin/xclip "$@"
      fi

      case "$OSTYPE" in
        darwin*) exec /usr/bin/pbpaste ;;
      esac

      echo "xclip: no clipboard output command found" >&2
      exit 1
      ;;
  esac
done

if [[ -n "$SSH_CONNECTION$SSH_TTY" ]]; then
  exec osc52-copy
fi

if [[ -x /usr/bin/xclip ]]; then
  exec /usr/bin/xclip "$@"
fi

case "$OSTYPE" in
  darwin*) exec /usr/bin/pbcopy ;;
esac

if [[ -x /usr/bin/wl-copy ]]; then
  exec /usr/bin/wl-copy "$@"
fi

echo "xclip: no clipboard input command found" >&2
exit 1

alias dotfiles='/usr/bin/git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'

alias aliasconf='nvim ~/.aliases'
alias vconf='cd ~/.config/nvim/lua && nvim'

alias qde='quasar dev -m electron'
alias qd='quasar dev'
alias ylf='yarn lint --fix'
alias yd='yarn dev'
alias ys='yarn start'

alias lnm='find . -name "node_modules" -type d -prune | xargs dust -cHp -d 1 -z 15m'
alias dnm='find . -name "node_modules" -type d -prune -exec rm -rf "{}" +'
alias dpnpm='find . -name "pnpm-lock.yaml" -type f -exec rm -f {} \;'

alias du='dust'
alias lg='lazygit'
alias lzd='lazydocker'
alias top='bpytop'
alias sz='source ~/.zshrc'
alias n='nvim'
alias lazyn='export XDG_CONFIG_HOME=~/.config/nvimA; export XDG_DATA_HOME=~/.local/share/nvimA; nvim'

alias tl='tmux ls'
alias tn='TERM=screen-256color tmux -u new -s'
alias td='tmux detach-client -E "exit"'

alias c.='cursor .'

alias psup='pass git pull && pass git push'

alias proton-bridge-cli='$HOME/.local/bin/proton-bridge-cli'
alias pbridge='proton-bridge-cli'

alias zj='zellij'
alias shoplift='zellij --layout shoplift'
alias firefly='zellij --layout firefly'
alias zjv='zellij --layout vite'
alias zjd='zellij --layout docs'
alias zjb='zellij --layout blank'
alias zjn='zellij --layout netlify'

alias tree='exa -a -T --icons --group-directories-first'

for a in :q :q!; do alias "$a"='exit'; done

alias sail='./vendor/bin/sail'
alias art='sail art'

alias d2i='gcd git@github.com:terrastruct/d2.git'
alias d2c='./ci/release/build.sh --install'
alias d2u='curl -fsSL https://d2lang.com/install.sh | sh -s -- --uninstall'

alias nnode='nvm use 19.5.0'
alias onode='nvm use 16.19.0'
alias kserv='npx kill-port 42069'

alias wo="pomodoro 'work'"
alias br="pomodoro 'break'"

alias envup='netlify env:import .env'
alias nssh='ssh-keygen -t ed25519'

alias gr='go run .'
alias gb='go build'
alias gmt='go mod tidy'
alias cr='cargo run'

alias prd='pnpm run dev'
alias pl='pnpm lint'
alias pt='pnpm typecheck'
alias dmig='pnpm drizzle-kit generate'

alias stats='neofetch'
alias gsync='~/scripts/git-auto-pull/git-auto-pull.sh'
alias tmux='TERM=tmux-256color tmux'
alias killghosttys='pkill -f ghostty'

alias cl='claude'
alias resume='claude -c'
mm-browser() {
    local url="${1:-http://127.0.0.1:3333/hyperliquid}"
    local devtools_url="http://127.0.0.1:9222/json/version"
    local forward="127.0.0.1:9222:127.0.0.1:9222"
    local control_path="$HOME/.ssh/cm/mm-browser-aether-%C"
    local identity="$HOME/.ssh/okeanos_ed25519"
    local i

    open -na "Google Chrome" --args --user-data-dir="$HOME/.chrome-mm-mcp" --remote-debugging-address=127.0.0.1 --remote-debugging-port=9222 --no-first-run --no-default-browser-check "$url"

    for i in {1..30}; do
        curl -fsS "$devtools_url" >/dev/null 2>&1 && break
        sleep 0.5
    done

    if ! curl -fsS "$devtools_url" >/dev/null 2>&1; then
        echo "Chrome DevTools is not listening on 127.0.0.1:9222"
        return 1
    fi

    if ssh -F /dev/null -i "$identity" -o IdentitiesOnly=yes -o BatchMode=yes -o ConnectTimeout=5 -o User=thevetat aether "curl -fsS '$devtools_url' >/dev/null" 2>/dev/null; then
        echo "mm-browser ready: aether can reach Chrome DevTools on 127.0.0.1:9222"
        return 0
    fi

    ssh -O cancel -R "$forward" aether >/dev/null 2>&1

    ssh -F /dev/null -i "$identity" -o IdentitiesOnly=yes -o ExitOnForwardFailure=yes -o ServerAliveInterval=30 -o ServerAliveCountMax=3 -o ControlMaster=auto -o ControlPersist=10m -o ControlPath="$control_path" -fN -R "$forward" thevetat@aether

    if ssh -F /dev/null -i "$identity" -o IdentitiesOnly=yes -o BatchMode=yes -o ConnectTimeout=5 -o User=thevetat aether "curl -fsS '$devtools_url' >/dev/null" 2>/dev/null; then
        echo "mm-browser ready: aether can reach Chrome DevTools on 127.0.0.1:9222"
        return 0
    fi

    echo "Chrome started locally, but aether cannot reach 127.0.0.1:9222"
    echo "Check aether with: ss -ltnp 'sport = :9222'"
    return 1
}

alias rrails='rbenv exec bundle exec rails'
alias rrake='rbenv exec bundle exec rake'

alias wv='$HOME/.local/bin/wv'
